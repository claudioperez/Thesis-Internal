@article{simo1986dynamicsa,
  title = {On the {{Dynamics}} of {{Flexible Beams Under Large Overall Motions}}—{{The Plane Case}}: {{Part I}}},
  shorttitle = {On the {{Dynamics}} of {{Flexible Beams Under Large Overall Motions}}—{{The Plane Case}}},
  author = {Simo, J. C. and Vu-Quoc, L.},
  date = {1986-12-01},
  journaltitle = {Journal of Applied Mechanics},
  volume = {53},
  number = {4},
  pages = {849--854},
  issn = {0021-8936, 1528-9036},
  doi = {10.1115/1.3171870},
  abstract = {The dynamic response of a flexible beam subject to large overall motions is traditionally formulated relative to a floating frame, sometimes referred to as the shadow beam. This type of formulation leads to equations of motion of the form g˜(y˙, y, t) = 0, that are implicit, nonlinear and highly coupled in the inertia terms. An alternative approach is proposed whereby all quantities are referred to the inertial frame. As a result, the inertia term enters linearly in the formulation simply as mass times acceleration. Crucial to this formulation is the use of finite strain rod theories capable of treating finite rotations. Numerical examples that involve finite vibrations coupled with large overall motions are presented in Part II of this paper.},
