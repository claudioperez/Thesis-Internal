@article{simo1986dynamics,
  title = {On the {{Dynamics}} of {{Flexible Beams Under Large Overall Motions}}—{{The Plane Case}}: {{Part II}}},
  shorttitle = {On the {{Dynamics}} of {{Flexible Beams Under Large Overall Motions}}—{{The Plane Case}}},
  author = {Simo, J. C. and Vu-Quoc, L.},
  date = {1986-12-01},
  journaltitle = {Journal of Applied Mechanics},
  volume = {53},
  number = {4},
