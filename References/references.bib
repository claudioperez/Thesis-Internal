@article{konstantinidis2007dynamics,
  title = {The Dynamics of a Rocking Block in Three Dimensions.},
  author = {Konstantinidis, Dimitrios and Makris, Nicos},
  date = {2007-07-14},
  pages = {10},
  abstract = {This paper follows two approaches to formulate the equations that describe the free rocking motion of a rigid block in three dimensions. In the first approach, the orientation of the block is parametrized using a 3-1-2 set of Euler angles, \{θ, φ, ψ\} . Lagrange’s equations of motion, where the Euler angles \{θ, φ, ψ\} serve as generalized coordinates, yield a system m(χ)χ = f(χ, χ) , where χ = \{θ,φ, ψ\} . This in turn, can be expressed as M(x)x = F(x) , where x = \{θ, φ, ψ, θ, φ, ψ\} . The paper shows that the familiar equation of planar rocking motion readily follows from the general formulation by constraining coordinates φ and ψ .},
  langid = {english}
