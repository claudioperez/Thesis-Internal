@article{garini2017evidence,
  title = {Evidence of Significant Forward Rupture Directivity Aggravated by Soil Response in an {{M}} {\textsubscript{w}} 6 Earthquake and the Effects on Monuments: {{Evidence}} of {{Forward Rupture Directivity}}},
  shorttitle = {Evidence of Significant Forward Rupture Directivity Aggravated by Soil Response in an {{M}} {\textsubscript{w}} 6 Earthquake and the Effects on Monuments},
  author = {Garini, E. and Gazetas, G. and Anastasopoulos, I.},
