  title = {{{HW5Frame}}\_{{Analysis}}},
  author = {Fenves, Gregory L.},
  abstract = {\% 3-story plane frame with distributed girder loads \% analysis script Frame\_Analysis.m \% Department of Civil and Environmental Engineering \% University of California, Berkeley \% \% Number of elements ne = Model.ne; \% Loop counter i = 1; \% Reference load increment dP = 0.5; \% Arrays for storing where and at what load level hinges form hinge = zeros(ne,2); \% Records sequence of hinge formation loads = zeros(ne,2); \% Records load level at which hinge forms hingeCount = 1; \% Arrays for storing where and at what load level hinges reach 0.015 rad hinge015 = zeros(ne,2); loads015 = zeros(ne,2); hinge015Count = 1; maxvp = 0; \% Loop until max plastic rotation of 0.03 rad is reached while maxvp {$<$} 0.03     \% specify nodal loads (non-zero terms only)     P = dP*i;     Pe(3,1) = 1*P;     Pe(5,1) = 2*P;     Pe(7,1) = 3*P;     \% Create loading on structure     Loading = Create\_Loading (Model,Pe);          \% Call NR\_Step for current load value     NR\_Step;          \% Store results in Post     Post(i) = Structure ('post',Model,ElData,State);          \% Iterate over elements to determine plastic rotation     for j = 1:ne         vp = Post(i).Elem\{j\}.vp(2:3);         absvp = abs(vp);                  \% Check if a hinge has formed at end 1 of element j         if (absvp(1) {$>$} 100*eps \& hinge(j,1) == 0)             hinge(j,1) = hingeCount;             loads(j,1) = P;             hingeCount = hingeCount+1;         end                  \% and check at end 2 of element j         if (absvp(2) {$>$} 100*eps \& hinge(j,2) == 0)             hinge(j,2) = hingeCount;             loads(j,2) = P;             hingeCount = hingeCount+1;         end                  \% Check if a hinge has reached 0.015 rad plastic rotation at end 1 of element j         if (absvp(1) {$>$} 0.015 \& hinge015(j,1) == 0)             hinge015(j,1) = hinge015Count;             loads015(j,1) = P;             hinge015Count = hinge015Count+1;         end                  \% and at end 2 of element j         if (absvp(2) {$>$} 0.015 \& hinge015(j,2) == 0)             hinge015(j,2) = hinge015Count;             loads015(j,2) = P;             hinge015Count = hinge015Count+1;         end         \% Check for maximum plastic rotation         maxabsvp = max(absvp);         if (maxabsvp {$>$} maxvp)             maxvp = maxabsvp;         end              end     \% Record base shear and roof displacement     BaseShear(i) = 6*P;     RoofDisp(i) = State.U(Model.DOF(1,7),1);                  i = i+1;      end \% plot deformed shape of structural model MAGF = 100;       \% magnification factor for deformed configuration Structure ('defo',Model,ElData,State); \% Plot bending moment diagram in new window Create\_Window(0.5,0.5); Plot\_Model(Model); Plot\_Force\_Distr(Model,ElData,Post(i-1),'Mz'); fclose(IOW);   \% close output file; figure; plot(RoofDisp,BaseShear); grid; xlabel('Roof Displacement (in)'); ylabel('Base Shear (kip)'); title(sprintf('Pushover Curve -- \%s',elem));}
