@article{scholz2019cartan,
  title = {E. {{Cartan}}’s Attempt at Bridge-Building between {{Einstein}} and the {{Cosserats}} – or How Translational Curvature Became to Be Known as Torsion},
  author = {Scholz, Erhard},
