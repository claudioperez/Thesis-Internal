@article{simo1994new,
  title = {A New Energy and Momentum Conserving Algorithm for the Non‐linear Dynamics of Shells},
  author = {Simo, J. C. and Tarnow, N.},
  date = {1994-08-15},
  journaltitle = {International Journal for Numerical Methods in Engineering},
  shortjournal = {Numerical Meth Engineering},
