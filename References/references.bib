@article{montalto2024effective,
  title = {Effective {{Warping Properties}} and {{Buckling Analysis}} of {{Fiber-Reinforced Elastomeric Isolators}}},
  author = {Montalto, Eduardo J. and Konstantinidis, Dimitrios},
  date = {2024-05},
  journaltitle = {Journal of Engineering Mechanics},
  shortjournal = {J. Eng. Mech.},
