@article{makinen2007total,
  title = {Total {{Lagrangian Reissner}}'s Geometrically Exact Beam Element without Singularities},
  author = {M{\"a}kinen, Jari},
  year = {2007},
  month = may,
  journal = {International Journal for Numerical Methods in Engineering},
  volume = {70},
  number = {9},
  pages = {1009--1048},
  issn = {00295981, 10970207},
  doi = {10.1002/nme.1892},
  urldate = {2020-03-24},
  abstract = {In this paper, we introduce a new Reissner's geometrically exact beam element, which is based on a total Lagrangian updating procedure. The element has the rotation vector as the dependent variable and the singularity problems at the rotation angle 2 and its multiples are passed by the change of parametrization on the rotation manifold. The beam formulation has several benefits such as all the unknown vectors belong to the same tangential vector space, no need for secondary storage variables, the path-independence in the static case, any standard time-integration algorithm may be used, and the symmetric stiffness. Copyright q 2006 John Wiley \& Sons, Ltd.},
  langid = {english},
  annotation = {67 citations (Crossref) [2022-06-27]}
}