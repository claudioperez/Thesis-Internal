  publisher = {Wiley},
  doi = {10.1002/9781119176817.ecm2119},
  abstract = {Abstract             Rotations play a fundamental role in many theories of classical, structural, continuum, and computational mechanics. Their mathematical and computational treatment is delicate because they do not possess the structure of a vector space but, instead, that of a Lie group. For this reason, many of the operations that are often carried out in a straightforward manner in linear spaces have to be re‐examined. In this chapter, we describe the fundamental aspects that need to be dealt with when employing rotations in numerical methods, namely their parameterization, update, interpolation, and linearization of functions on rotations. Additionally, two key applications are presented: the integration of the rigid body equations, and the approximation of the equations of geometrically exact rods.},
